{
  "name": "tirak-backend",
  "version": "1.0.0",
  "description": "Tirak guided-experience marketplace backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "./scripts/deploy.sh staging",
    "deploy:production": "./scripts/deploy.sh production",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "release:verify": "npm run typecheck && npm run test:run && node scripts/verify-release-gate.mjs",
    "release:verify:static": "node scripts/verify-release-gate.mjs",
    "release:verify:negative": "node scripts/release-negative-matrix.mjs",
    "db:migrate:development": "npx wrangler d1 migrations apply tirak-development --env development --local",
    "db:migrate:staging": "npx wrangler d1 migrations apply tirak-staging --env staging --remote",
    "db:migrate:production": "npx wrangler d1 migrations apply tirak-mobile-production --env production --remote",
    "db:seed:development": "npx wrangler d1 execute tirak-development --env development --local --file ./scripts/seed-data.sql",
    "logs": "wrangler tail --format pretty",
    "logs:staging": "wrangler tail --env staging --format pretty",
    "logs:production": "wrangler tail --env production --format pretty"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "api",
    "backend",
    "tirak"
  ],
  "author": "Tirak Team",
  "license": "MIT",
  "dependencies": {
    "@hono/zod-validator": "^0.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "bcryptjs": "^3.0.2",
    "hono": "^4.7.11",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250607.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.8.6",
    "@vitest/coverage-v8": "^3.2.4",
    "happy-dom": "^12.10.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "wrangler": "^4.93.0"
  }
}
