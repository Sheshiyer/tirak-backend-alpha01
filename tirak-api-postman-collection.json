              "host": ["{{baseUrl}}"],
              "path": ["api", "search", "suppliers"],
              "query": [
                {
                  "key": "region",
                  "value": "bangkok",
                  "description": "optional"
                },
                {
                  "key": "category",
                  "value": "massage",
                  "description": "optional"
                },
                {
                  "key": "priceMin",
                  "value": "300",
                  "description": "optional"
                },
                {
                  "key": "priceMax",
                  "value": "1000",
                  "description": "optional"
                },
                {
                  "key": "language",
                  "value": "en",
                  "description": "optional"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "optional, default: 1"
                },
                {
                  "key": "limit",
                  "value": "20",
                  "description": "optional, default: 20"
                },
                {
                  "key": "sortBy",
                  "value": "rating",
                  "description": "optional: rating, price, distance, created"
