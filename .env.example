# Copy this file to .env.tirak-staging and run: chmod 600 .env.tirak-staging
# Never commit the populated file or paste its token into chat, issues, or logs.
# Prefer this-account-only reads: Workers Scripts, D1, Workers KV Storage,
# Workers R2 Storage, and Queues. A full-scoped token is unnecessary; rotate it
# under separate secret-mutation authority before later sensitive work.
TIRAK_CLOUDFLARE_API_TOKEN=
